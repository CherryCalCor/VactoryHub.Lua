local function CreateCompactSelectionMenu(parent, title, items, onToggleCallback)
    local categoryFrame = CreateStyledCard(parent, 40)
    categoryFrame.AutomaticSize = Enum.AutomaticSize.Y
    Create("UIPadding", { Parent = categoryFrame, PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12) })

    local header = Create("TextButton", {
        Parent = categoryFrame,
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Colors.TextMain,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    local arrow = Create("TextLabel", {
        Parent = header,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 20, 1, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = Colors.TextDim,
        Font = Enum.Font.GothamMedium,
        TextSize = 12
    })

    local grid = Create("Frame", {
        Parent = categoryFrame,
        Position = UDim2.new(0, 0, 0, 30),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        Visible = false,
        ClipsDescendants = true
    })
    local gridLayout = Create("UIGridLayout", {
        Parent = grid,
        CellSize = UDim2.new(0, 130, 0, 30),
        CellPadding = UDim2.new(0, 8, 0, 8),
        SortOrder = Enum.SortOrder.Name
    })
    
    gridLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if grid.Visible then
            grid.Size = UDim2.new(1, 0, 0, gridLayout.AbsoluteContentSize.Y)
        end
    end)

    local isExpanded = false
    header.MouseButton1Click:Connect(function()
        isExpanded = not isExpanded
        grid.Visible = isExpanded
        arrow.Text = isExpanded and "▲" or "▼"
        grid.Size = UDim2.new(1, 0, 0, isExpanded and gridLayout.AbsoluteContentSize.Y or 0)
    end)

    for _, itemName in ipairs(items) do
        local btn = Create("TextButton", {
            Name = itemName,
            Parent = grid,
            BackgroundColor3 = Colors.Background,
            Text = itemName,
            TextColor3 = Colors.TextDim,
            Font = Enum.Font.GothamMedium,
            TextSize = 12,
            AutoButtonColor = false
        })
        Create("UICorner", { Parent = btn, CornerRadius = UDim.new(0, 4) })
        local bStroke = Create("UIStroke", { Parent = btn, Color = Colors.Border, Thickness = 1 })

        btn.MouseButton1Click:Connect(function()
            local isActive = not ActiveFarms[itemName]
            ActiveFarms[itemName] = isActive

            if isActive then
                TweenService:Create(btn, TWEEN_INFO_FAST, {
                    TextColor3 = Color3.fromRGB(20, 20, 20), 
                    BackgroundColor3 = Colors.TextMain       
                }):Play()
                TweenService:Create(bStroke, TWEEN_INFO_FAST, {Color = Colors.TextMain}):Play()
            else
                TweenService:Create(btn, TWEEN_INFO_FAST, {
                    TextColor3 = Colors.TextDim,             
                    BackgroundColor3 = Colors.Background     
                }):Play()
                TweenService:Create(bStroke, TWEEN_INFO_FAST, {Color = Colors.Border}):Play()
            end
            if onToggleCallback then onToggleCallback(itemName, isActive) end
        end)
    end
end

