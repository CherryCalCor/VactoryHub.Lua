        if ActiveTab ~= tabName then TweenService:Create(Btn, TWEEN_INFO_FAST, {TextColor3 = Color3.fromRGB(210, 210, 210)}):Play() end
    end)
    Btn.MouseLeave:Connect(function()
        if ActiveTab ~= tabName then TweenService:Create(Btn, TWEEN_INFO_FAST, {TextColor3 = Colors.TextDim}):Play() end
    end)

    Btn.MouseButton1Click:Connect(function()
        if ActiveTab == tabName then return end
        
        for _, child in pairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") and child.Name ~= tabName.."Btn" then
                TweenService:Create(child, TWEEN_INFO_SMOOTH, {TextColor3 = Colors.TextDim}):Play()
                TweenService:Create(child.Indicator, TWEEN_INFO_SMOOTH, {Size = UDim2.new(0, 2, 0, 0), BackgroundTransparency = 1}):Play()
            end
        end

        if ActiveTab and Tabs[ActiveTab] then
            local oldTab = Tabs[ActiveTab]
            local outTween = TweenService:Create(oldTab, TWEEN_INFO_FAST, {Position = UDim2.new(0, 0, 0, 10)})
            outTween:Play()
            outTween.Completed:Wait()
            oldTab.Visible = false
        end

        ActiveTab = tabName
        TweenService:Create(Btn, TWEEN_INFO_SMOOTH, {TextColor3 = Colors.TextMain}):Play()
        TweenService:Create(Indicator, TWEEN_INFO_SMOOTH, {Size = UDim2.new(0, 3, 0, 18), BackgroundTransparency = 0}):Play()

        local targetTab = Tabs[tabName]
        if targetTab then
            targetTab.Position = UDim2.new(0, 0, 0, 10)
            targetTab.Visible = true
            TweenService:Create(targetTab, TWEEN_INFO_SMOOTH, {Position = UDim2.new(0, 0, 0, 0)}):Play()
        end
    end)
end

