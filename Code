                            for _, fruit in pairs(fruitsFolder:GetChildren()) do
                                hrp.CFrame = plant:GetPivot()
                                local fruitId = string.split(fruit.Name, "_")[3]
                                if fruitId and CollectFruit then
                                    task.wait(0.2)
                                    pcall(function() CollectFruit:Fire(plant:GetAttribute("PlantId"), fruitId) end)
                                end
                            end
                        end
                    end
                end
                task.wait(1)
            end
        end)
    end
end)

