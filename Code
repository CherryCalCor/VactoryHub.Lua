CreateGitHubToggle(CollectControlCard, "Teleport Collect", false, function(state)
    tpCollectEnabled = state
    if state then
        task.spawn(function()
            while tpCollectEnabled do
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp and plantsFolder then
                    for _, plant in pairs(plantsFolder:GetChildren()) do
                        if not tpCollectEnabled then break end
                        local fruitsFolder = plant:FindFirstChild("Fruits")
