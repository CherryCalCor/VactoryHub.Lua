local function CreateGitHubToggle(parent, text, defaultState, callback)
    local row = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        Parent = parent
    })

    Create("TextLabel", {
        Parent = row,
        Size = UDim2.new(1, -50, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.TextMain,
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local switchShell = Create("Frame", {
        Parent = row,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 38, 0, 22),
        BackgroundColor3 = Colors.ToggleShell
    })
    Create("UICorner", { Parent = switchShell, CornerRadius = UDim.new(0, 5) })
    local stroke = Create("UIStroke", { Parent = switchShell, Color = Colors.Border, Thickness = 1 })

    local knob = Create("Frame", {
        Parent = switchShell,
        Position = defaultState and UDim2.new(1, -19, 0, 3) or UDim2.new(0, 3, 0, 3),
        Size = UDim2.new(0, 16, 0, 16),
        BackgroundColor3 = defaultState and Colors.TextMain or Colors.TextDim
    })
    Create("UICorner", { Parent = knob, CornerRadius = UDim.new(0, 4) })

    local clickArea = Create("TextButton", {
        Parent = switchShell,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false
    })

    local state = defaultState
    clickArea.MouseButton1Click:Connect(function()
        state = not state
        local targetPos = state and UDim2.new(1, -19, 0, 3) or UDim2.new(0, 3, 0, 3)
        local targetColor = state and Colors.TextMain or Colors.TextDim
        local borderHex = state and Colors.TextMain or Colors.Border

        TweenService:Create(knob, TWEEN_INFO_FAST, {Position = targetPos, BackgroundColor3 = targetColor}):Play()
        TweenService:Create(stroke, TWEEN_INFO_FAST, {Color = borderHex}):Play()
        
        if callback then callback(state) end
    end)

    return row
end

